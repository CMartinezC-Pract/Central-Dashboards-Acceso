@page
@model CentralDashboards.Pages.Solicitudes.DetailModel
@using CentralDashboards.Pages.Shared
@{
    ViewData["Title"] = $"Solicitud {Model.Solicitud?.Folio}";
    var inc = Model.Solicitud!;
    var esAdmin = User.IsInRole("Administrador");
}

<!-- HEADER -->
<div class="detail-header">
    <a href="/Solicitudes" class="btn-back-sq"><i class="bi bi-arrow-left"></i></a>

    <div class="detail-header-text">
        <div class="detail-title-row">
            <h2>@inc.Titulo</h2>
            <span class="badge-status" style="background:@(inc.ColorEstatus ?? "#6c757d")">
                <i class="bi bi-circle-fill" style="font-size:.4rem;"></i>
                @inc.NombreEstatus
            </span>
        </div>
        <div class="detail-meta">
            <span class="chip-folio chip-folio-sol">@inc.Folio</span>
            <span class="detail-meta-sep">·</span>
            <span>Dashboard: <strong>@inc.NombreDashboard</strong></span>
            <span class="detail-meta-sep">·</span>
            <span>Solicitado por <strong>@inc.ReportadoPor</strong></span>
            @if (!string.IsNullOrEmpty(inc.AreaReportador))
            {
                <span class="detail-meta-sep">·</span>
                <span><i class="bi bi-building me-1"></i>@inc.AreaReportador</span>
            }
            <span class="detail-meta-sep">·</span>
            <span>@inc.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</span>
        </div>
    </div>

    @if (esAdmin)
    {
        <a href="/Solicitudes/Edit?id=@inc.SolicitudID" class="btn-cd-primary">
            <i class="bi bi-pencil-fill"></i> Editar / Cambiar estatus
        </a>
    }
</div>

<!-- MENSAJES TEMPDATA -->
@if (TempData["Ok"] is string msgOk)
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-3" role="alert">
        <i class="bi bi-check-circle-fill"></i> @msgOk
    </div>
}
@if (TempData["Error"] is string msgErr)
{
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i> @msgErr
    </div>
}

<!-- ACCIONES RÁPIDAS — solo admin -->
@if (esAdmin)
{
    <div class="quick-actions-bar">
        <span class="quick-actions-label">
            <i class="bi bi-lightning-charge-fill"></i> Acciones rápidas
        </span>

        @* Ir al Dashboard directamente *@
        @if (inc.DashboardID > 0)
        {
            <a href="/Dashboards/Ver?DashboardId=@inc.DashboardID"
                   class="btn-quick btn-quick-dash" target="_blank">
                <i class="bi bi-grid-fill"></i>
                Ver Dashboard
                <span class="btn-quick-sub">@inc.NombreDashboard</span>
            </a>
        }

        @* Otorgar permiso directo *@
        @if (inc.DashboardID > 0)
        {
            if (Model.YaTienePermiso)
            {
                <span class="btn-quick btn-quick-disabled">
                    <i class="bi bi-shield-check-fill"></i>
                    Ya tiene acceso
                    <span class="btn-quick-sub">@inc.ReportadoPor</span>
                </span>
            }
            else
            {
                <form method="post" asp-page-handler="OtorgarPermiso" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="solicitudId" value="@inc.SolicitudID" />
                    <button type="submit" class="btn-quick btn-quick-permiso"
                            onclick="return confirm('¿Otorgar acceso al dashboard \" @inc.NombreDashboard\" para @inc.ReportadoPor?')">
                        <i class="bi bi-shield-plus-fill"></i>
                        Otorgar permiso
                        <span class="btn-quick-sub">@inc.ReportadoPor</span>
                    </button>
                </form>
            }
        }

       
    </div>
}

<!-- LAYOUT -->
<div class="detail-layout">
    <aside>
        <div class="sidebar-card">
            <div class="sidebar-card-header">
                <i class="bi bi-info-circle-fill"></i> Detalles del ticket
            </div>
            <div class="sidebar-card-body">
                <div class="detail-row">
                    <span class="dr-label">Folio</span>
                    <span class="dr-val"><span class="chip-folio chip-folio-sol">@inc.Folio</span></span>
                </div>
                <div class="detail-row">
                    <span class="dr-label">Tipo</span>
                    <span class="dr-val">@inc.TipoSolicitud</span>
                </div>
                <div class="detail-row">
                    <span class="dr-label">Prioridad</span>
                    <div style="margin-top:.25rem;">
                        @{
                            var priClass = inc.Prioridad switch
                            {
                                "Alta" => "badge-pri-alta",
                                "Media" => "badge-pri-media",
                                _ => "badge-pri-baja"
                            };
                            var priIco = inc.Prioridad switch
                            {
                                "Alta" => "bi-arrow-up-circle-fill",
                                "Media" => "bi-dash-circle-fill",
                                "Critica" => "bi-exclamation-octagon-fill",
                                _ => "bi-arrow-down-circle-fill"
                            };
                        }
                        <span class="badge-pill @priClass">
                            <i class="bi @priIco"></i> @inc.Prioridad
                        </span>
                    </div>
                </div>
                <div class="detail-row">
                    <span class="dr-label">Estatus</span>
                    <span class="dr-val">
                        <span class="badge-status" style="background:@(inc.ColorEstatus ?? "#6c757d")">
                            <i class="bi bi-circle-fill" style="font-size:.4rem;"></i>
                            @inc.NombreEstatus
                        </span>
                    </span>
                </div>
                <div class="detail-row">
                    <span class="dr-label">Solicitado por</span>
                    <span class="dr-val">
                        <span style="display:flex;align-items:center;gap:.4rem;">
                            <i class="bi bi-person-fill" style="color:var(--c-sol);"></i>
                            @inc.ReportadoPor
                        </span>
                        @if (!string.IsNullOrEmpty(inc.AreaReportador))
                        {
                            <span style="display:inline-flex;align-items:center;gap:.3rem;font-size:.7rem;color:var(--c-ink-3);margin-top:.25rem;">
                                <i class="bi bi-building"></i> @inc.AreaReportador
                            </span>
                        }
                    </span>
                </div>
                <div class="detail-row">
                    <span class="dr-label">Asignado a</span>
                    <span class="dr-val">
                        @if (!string.IsNullOrEmpty(inc.AsignadoA))
                        {
                            <span style="display:flex;align-items:center;gap:.4rem;">
                                <i class="bi bi-person-circle" style="color:var(--c-sol);"></i>
                                @inc.AsignadoA
                            </span>
                        }
                        else
                        {
                            <em style="color:var(--c-ink-4);font-size:.8rem;">Sin asignar</em>
                        }
                    </span>
                </div>
                @if (inc.FechaResolucion.HasValue)
                {
                    <div class="detail-row">
                        <span class="dr-label">Resuelto</span>
                        <span class="dr-val" style="color:var(--c-success);">
                            <i class="bi bi-check-circle-fill me-1"></i>
                            @inc.FechaResolucion.Value.ToString("dd/MM/yyyy")
                        </span>
                    </div>
                }
            </div>
        </div>
    </aside>

    <main>
        <div class="content-card">
            <div class="content-card-header">
                <i class="bi bi-file-text-fill"></i> Descripción de la solicitud
            </div>
            <div class="content-card-body">@inc.Descripcion</div>
        </div>

        @Html.AntiForgeryToken()
        @await Html.PartialAsync("_ComentariosPanel", new ComentariosPanelModel
        {
            TipoRegistro = "Solicitud",
            RegistroId = inc.SolicitudID,
            Comentarios = Model.Comentarios
        })
    </main>
</div>

<div><br /></div>
@await Html.PartialAsync("_GaleriaImagenes", Model.Imagenes)

@section Scripts {
    @* El script del panel de comentarios se renderiza desde el partial *@
}
