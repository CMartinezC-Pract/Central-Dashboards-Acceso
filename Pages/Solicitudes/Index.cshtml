@page
@model CentralDashboards.Pages.Solicitudes.IndexModel
@{
    ViewData["Title"] = "Solicitudes";
}

<div class="page-header">
    <div style="display:flex;align-items:center;gap:.75rem;">
        <div class="module-icon sol"><i class="bi bi-send-fill"></i></div>
        <div>
            <h4 class="page-header-title">Solicitudes</h4>
            <p class="page-header-sub">Registro y seguimiento de solicitudes de dashboards</p>
        </div>
    </div>
</div>

<!-- FILTROS -->
<form method="get" class="filtros-card">
    <div class="filtros-row">
        <div class="filtros-group">
            <label class="filtros-label">Estatus</label>
            <select name="EstatusId" class="cd-select">
                <option value="">Todos los estatus</option>
                @foreach (var e in Model.Estatus)
                {
                    <option value="@e.EstatusID" selected="@(Model.EstatusId == e.EstatusID)">@e.NombreEstatus</option>
                }
            </select>
        </div>
        <div class="filtros-btns">
            <button type="submit" class="btn-cd-primary">
                <i class="bi bi-funnel-fill"></i> Filtrar
            </button>
            <a href="/Solicitudes" class="btn-cd-secondary">
                <i class="bi bi-x-circle"></i> Limpiar
            </a>
        </div>
    </div>
</form>

<!-- TABLA -->
<div class="cd-table-wrap">
    <div class="cd-table-scroll">
        <table class="cd-table">
            <thead>
                <tr>
                    <th>Folio</th>
                    <th>Título</th>
                    <th>Dashboard</th>
                    <th>Solicitado por</th>
                    <th>Prioridad</th>
                    <th>Estatus</th>
                    <th>Fecha</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Solicituds.Any())
                {
                    <tr>
                        <td colspan="8">
                            <div class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <p>No hay solicitudes registradas</p>
                            </div>
                        </td>
                    </tr>
                }
                @foreach (var i in Model.Solicituds)
                {
                    <tr class="clickable" onclick="location.href='/Solicitudes/Detail?id=@i.SolicitudID'">
                        <td><span class="chip-folio chip-folio-sol">@i.Folio</span></td>
                        <td style="font-weight:700;color:var(--c-ink);">@i.Titulo</td>
                        <td style="font-size:.78rem;color:var(--c-ink-3);">@i.NombreDashboard</td>
                        <td style="font-size:.78rem;color:var(--c-ink-3);">@i.SolicitadoPor</td>
                        <td>
                            @{
                                var priClass = i.Prioridad switch
                                {
                                                "Alta" => "badge-pri-alta",
                                                "Media" => "badge-pri-media",
                                    _ => "badge-pri-baja"
                                };
                                var priIco = i.Prioridad switch
                                {
                                                "Alta" => "bi-arrow-up-circle-fill",
                                                "Media" => "bi-dash-circle-fill",
                                    _ => "bi-arrow-down-circle-fill"
                                };
                            }
                            <span class="badge-pill @priClass">
                                <i class="bi @priIco"></i> @i.Prioridad
                            </span>
                        </td>
                        <td>
                            <span class="badge-status" style="background:@(i.ColorEstatus ?? "#6c757d")">
                                <i class="bi bi-circle-fill" style="font-size:.4rem;"></i>
                                @i.NombreEstatus
                            </span>
                        </td>
                        <td style="font-size:.75rem;color:var(--c-ink-3);">@i.FechaCreacion.ToString("dd/MM/yy")</td>
                        <td onclick="event.stopPropagation()">
                            <div style="display:flex;gap:.35rem;">
                                <a href="/Solicitudes/Detail?id=@i.SolicitudID"
                                   class="btn-tbl btn-tbl-view" title="Ver detalle">
                                    <i class="bi bi-eye-fill"></i>
                                </a>
                                @if (User.IsInRole("Administrador"))
                                {
                                    <a href="/Solicitudes/Edit?id=@i.SolicitudID"
                                       class="btn-tbl btn-tbl-edit" title="Editar">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
